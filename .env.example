# Cerid AI — Environment Variables
# Copy to .env and fill in your values, then run: scripts/env-lock.sh
#
# REQUIRED: You MUST set NEO4J_PASSWORD, OPENROUTER_API_KEY, and OPENAI_API_KEY.
# OPTIONAL: Everything else has sensible defaults for local development.

# === Secrets (required — no defaults) ===
NEO4J_PASSWORD=                              # REQUIRED — auto-generated by setup.sh if empty
OPENROUTER_API_KEY=                          # REQUIRED — get one at https://openrouter.ai/keys
OPENAI_API_KEY=                              # REQUIRED — get one at https://platform.openai.com/api-keys

# === Infrastructure Auth (defaults for dev, change for production) ===
REDIS_PASSWORD=cerid-dev

# === Port Overrides (optional — defaults work for most setups) ===
# CERID_PORT_GUI=3000                       # React GUI
# CERID_PORT_MCP=8888                       # MCP Server API
# CERID_PORT_BIFROST=8080                   # Bifrost LLM Gateway
# CERID_PORT_NEO4J=7474                     # Neo4j HTTP
# CERID_PORT_NEO4J_BOLT=7687               # Neo4j Bolt protocol
# CERID_PORT_CHROMA=8001                    # ChromaDB
# CERID_PORT_REDIS=6379                     # Redis

# === Network & Access (optional) ===
# CERID_HOST=                             # LAN IP or hostname (auto-detected by start-cerid.sh)
# CERID_GATEWAY=false                     # Set to 'true' to start Caddy reverse proxy (HTTPS)
# CLOUDFLARE_TUNNEL_TOKEN=                # Set to enable Cloudflare Tunnel for public demos

# === MCP Config (optional) ===
CATEGORIZE_MODE=smart
# BIFROST_URL=http://bifrost:8080/v1
# WATCH_FOLDER=/archive
# DATA_DIR=data
# CERID_API_KEY=your-secret-api-key
# CORS_ORIGINS=http://localhost:3000,http://cerid-web
# ENABLE_FEEDBACK_LOOP=true
# WEBHOOK_URLS=https://your-webhook.example.com/cerid
# TRUSTED_PROXIES=                      # Comma-separated CIDRs for X-Forwarded-For (e.g., 172.16.0.0/12)
# OCR_ENGINE=docling                    # OCR engine for plugin system (pro tier)

# === Schedule Overrides (optional, cron expressions) ===
# SCHEDULE_RECTIFY=0 3 * * *
# SCHEDULE_HEALTH_CHECK=0 */6 * * *
# SCHEDULE_STALE_DETECTION=0 4 * * 0
# SCHEDULE_STALE_DAYS=90

# === Database URLs (optional, defaults point to Docker container names) ===
# REDIS_URL=redis://ai-companion-redis:6379
# CHROMA_URL=http://ai-companion-chroma:8000
# NEO4J_URI=bolt://ai-companion-neo4j:7687
# NEO4J_USER=neo4j

# === Retrieval Tuning (optional) ===
# CHUNKING_MODE=semantic                  # "semantic" or "token"
# HYBRID_VECTOR_WEIGHT=0.6
# HYBRID_KEYWORD_WEIGHT=0.4
# RERANK_LLM_WEIGHT=0.6
# RERANK_ORIGINAL_WEIGHT=0.4
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_DIMENSIONS=384
# BIFROST_TIMEOUT=30.0                    # LLM gateway timeout in seconds

# === Verification (optional) ===
# VERIFICATION_MODEL=openrouter/openai/gpt-4o-mini
# VERIFICATION_CURRENT_EVENT_MODEL=openrouter/x-ai/grok-4-fast:online
# ENABLE_EXTERNAL_VERIFICATION=true
# EXTERNAL_VERIFY_MODEL=openrouter/openai/gpt-4o-mini
# EXTERNAL_VERIFY_MAX_CONCURRENT=5

# === Phase 7A: Audit Intelligence (optional) ===
# ENABLE_HALLUCINATION_CHECK=false
# HALLUCINATION_THRESHOLD=0.75

# === Phase 7B: Smart Orchestration (optional) ===
# ENABLE_MODEL_ROUTER=false
# COST_SENSITIVITY=medium

# === Phase 7C: Proactive Knowledge (optional) ===
# ENABLE_MEMORY_EXTRACTION=false
# MEMORY_RETENTION_DAYS=180

# === Self-RAG Validation Loop (optional) ===
# ENABLE_SELF_RAG=false                    # Enable claim-based retrieval refinement
# SELF_RAG_MAX_ITERATIONS=2               # Max refinement iterations per request
# SELF_RAG_WEAK_CLAIM_THRESHOLD=0.5       # Claims below this similarity are "weak"
# SELF_RAG_MAX_REFINED_QUERIES=3          # Max weak claims used as refined queries
# SELF_RAG_REFINED_TOP_K=5               # Results per refined query

# === Paths & Storage (optional) ===
# ARCHIVE_PATH=/archive                   # Container-side mount point
# WATCH_FOLDER=~/cerid-archive            # Host-side watcher path
# CERID_STORAGE_MODE=extract_only         # extract_only | archive (archive copies files to sync dir)

# === Sync Config (optional) ===
# CERID_SYNC_DIR=~/Dropbox/cerid-sync
# CERID_MACHINE_ID=my-hostname
# CERID_SYNC_BACKEND=local
# SCHEDULE_SYNC_EXPORT=                   # Cron string for scheduled export (empty = disabled)
# SYNC_EXPORT_ON_INGEST=false             # Auto-export after each ingest
# CERID_CONFLICT_STRATEGY=remote_wins     # remote_wins | local_wins | keep_both | manual_review
# TOMBSTONE_TTL_DAYS=90                   # Days before expired tombstones are purged

# === Phase 8D: Encryption (optional) ===
# ENABLE_ENCRYPTION=false
# CERID_ENCRYPTION_KEY=
# Generate a key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# === Multi-User Auth (optional — disabled by default) ===
# CERID_MULTI_USER=false                  # Enable JWT auth, user registration, per-user API keys
# CERID_JWT_SECRET=                       # REQUIRED when multi-user — generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
# CERID_JWT_ACCESS_TTL=900               # Access token TTL in seconds (default: 15 min)
# CERID_JWT_REFRESH_TTL=604800           # Refresh token TTL in seconds (default: 7 days)
# CERID_DEFAULT_TENANT=default           # Default tenant ID for single-user mode

# === Phase 8A: Plugin System & Feature Tiers (optional) ===
# CERID_TIER=community
# CERID_PLUGIN_DIR=plugins
# CERID_ENABLED_PLUGINS=

# === Phase 8C: Hierarchical Taxonomy (optional) ===
# Custom domains as JSON (merged with built-in taxonomy)
# CERID_CUSTOM_DOMAINS={"research": {"description": "Research papers", "icon": "book", "sub_categories": ["papers", "notes", "general"]}}
