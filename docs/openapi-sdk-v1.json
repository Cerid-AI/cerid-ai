    "/sdk/v1/hallucination": {
      "post": {
        "description": "Verify factual claims in a response against the KB. Returns per-claim status (verified/unverified/uncertain) with sources and confidence scores.",
        "operationId": "sdk_hallucination_sdk_v1_hallucination_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HallucinationCheckRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SDKHallucinationResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "description": "Invalid request parameters"
          },
          "503": {
            "description": "One or more backend services unavailable"
          }
        },
        "summary": "Hallucination Detection",
        "tags": [
          "SDK"
        ]
      }
    },
