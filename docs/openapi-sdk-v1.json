{
  "components": {
    "schemas": {
      "AgentQueryRequest": {
        "properties": {
          "context_sources": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "description": "Source gates: {kb: bool, memory: bool, external: bool}. None = all enabled. Disabled sources skip retrieval entirely.",
            "title": "Context Sources"
          },
          "conversation_messages": {
            "anyOf": [
              {
                "items": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Conversation Messages"
          },
          "cost_sensitivity": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "User cost preference: 'low' | 'medium' | 'high'. When None the server resolves it from the consumer registry (Task 17).",
            "title": "Cost Sensitivity"
          },
          "domains": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Domains"
          },
          "enable_self_rag": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "description": "Override Self-RAG toggle (None = use server config)",
            "title": "Enable Self Rag"
          },
          "metadata_filter": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "description": "ChromaDB where-clause for metadata filtering (e.g. {\"filename\": \"report.pdf\"})",
            "title": "Metadata Filter"
          },
          "model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Generating model (for Self-RAG metadata)",
            "title": "Model"
          },
          "query": {
            "title": "Query",
            "type": "string"
          },
          "query_scope": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Query scope: document | domain | kb (None = kb)",
            "title": "Query Scope"
          },
          "rag_mode": {
            "default": "manual",
            "description": "Retrieval mode: manual | smart | custom_smart",
            "title": "Rag Mode",
            "type": "string"
          },
          "response_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "LLM response text for Self-RAG validation",
            "title": "Response Text"
          },
          "scope_ref": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Scope reference \u2014 filename for 'document' scope",
            "title": "Scope Ref"
          },
          "skip_cache": {
            "default": false,
            "description": "Bypass semantic cache and query cache (for fresh-data scenarios like setup wizard)",
            "title": "Skip Cache",
            "type": "boolean"
          },
          "source_config": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "description": "Source weights/toggles for custom_smart mode",
            "title": "Source Config"
          },
          "strict_domains": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "description": "When True, disables cross-domain affinity bleed. None = use consumer default.",
            "title": "Strict Domains"
          },
          "top_k": {
            "default": 10,
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Top K",
            "type": "integer"
          },
          "use_reranking": {
            "default": true,
            "title": "Use Reranking",
            "type": "boolean"
          }
        },
        "required": [
          "query"
        ],
        "title": "AgentQueryRequest",
        "type": "object"
      },
      "HallucinationCheckRequest": {
        "properties": {
          "conversation_id": {
            "title": "Conversation Id",
            "type": "string"
          },
          "expert_mode": {
            "default": false,
            "title": "Expert Mode",
            "type": "boolean"
          },
          "model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model"
          },
          "persist": {
            "default": true,
            "title": "Persist",
            "type": "boolean"
          },
          "response_text": {
            "title": "Response Text",
            "type": "string"
          },
          "threshold": {
            "anyOf": [
              {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Threshold"
          },
          "user_query": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "User Query"
          }
        },
        "required": [
          "response_text",
          "conversation_id"
        ],
        "title": "HallucinationCheckRequest",
        "type": "object"
      },
      "MemoryExtractionRequest": {
        "properties": {
          "conversation_id": {
            "title": "Conversation Id",
            "type": "string"
          },
          "model": {
            "default": "",
            "title": "Model",
            "type": "string"
          },
          "response_text": {
            "title": "Response Text",
            "type": "string"
          }
        },
        "required": [
          "response_text",
          "conversation_id"
        ],
        "title": "MemoryExtractionRequest",
        "type": "object"
      },
      "SDKHallucinationResponse": {
        "additionalProperties": true,
        "description": "Response from ``POST /sdk/v1/hallucination`` \u2014 claim verification.",
        "properties": {
          "claims": {
            "description": "Verified claims with status, confidence, and source info",
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Claims",
            "type": "array"
          },
          "conversation_id": {
            "default": "",
            "description": "Conversation identifier",
            "title": "Conversation Id",
            "type": "string"
          },
          "reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Reason verification was skipped, if applicable",
            "title": "Reason"
          },
          "skipped": {
            "default": false,
            "description": "True if verification was skipped (response too short or no claims)",
            "title": "Skipped",
            "type": "boolean"
          },
          "summary": {
            "additionalProperties": {
              "type": "integer"
            },
            "description": "Claim verification counts by status",
            "title": "Summary",
            "type": "object"
          },
          "timestamp": {
            "default": "",
            "description": "ISO 8601 verification timestamp",
            "title": "Timestamp",
            "type": "string"
          }
        },
        "title": "SDKHallucinationResponse",
        "type": "object"
      },
      "SDKHealthResponse": {
        "additionalProperties": true,
        "description": "Response from ``GET /sdk/v1/health`` \u2014 service health with feature flags.",
        "properties": {
          "features": {
            "additionalProperties": {
              "type": "boolean"
            },
            "description": "Consumer-relevant feature toggles",
            "title": "Features",
            "type": "object"
          },
          "services": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "Per-service connectivity status",
            "title": "Services",
            "type": "object"
          },
          "status": {
            "description": "Overall status: 'healthy' or 'degraded'",
            "title": "Status",
            "type": "string"
          },
          "version": {
            "description": "API version string",
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "version",
          "services"
        ],
        "title": "SDKHealthResponse",
        "type": "object"
      },
      "SDKMemoryExtractResponse": {
        "additionalProperties": true,
        "description": "Response from ``POST /sdk/v1/memory/extract`` \u2014 memory extraction and storage.",
        "properties": {
          "conversation_id": {
            "default": "",
            "description": "Conversation identifier",
            "title": "Conversation Id",
            "type": "string"
          },
          "memories_extracted": {
            "default": 0,
            "description": "Number of memories extracted from text",
            "minimum": 0.0,
            "title": "Memories Extracted",
            "type": "integer"
          },
          "memories_stored": {
            "default": 0,
            "description": "Number successfully stored in KB",
            "minimum": 0.0,
            "title": "Memories Stored",
            "type": "integer"
          },
          "results": {
            "description": "Per-memory outcome (status, type, summary)",
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Results",
            "type": "array"
          },
          "skipped_duplicates": {
            "default": 0,
            "description": "Memories skipped due to deduplication",
            "minimum": 0.0,
            "title": "Skipped Duplicates",
            "type": "integer"
          },
          "timestamp": {
            "default": "",
            "description": "ISO 8601 extraction timestamp",
            "title": "Timestamp",
            "type": "string"
          }
        },
        "title": "SDKMemoryExtractResponse",
        "type": "object"
      },
      "SDKQueryResponse": {
        "additionalProperties": true,
        "description": "Response from ``POST /sdk/v1/query`` \u2014 multi-domain KB search.",
        "properties": {
          "confidence": {
            "default": 0.0,
            "description": "Average relevance of returned sources",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence",
            "type": "number"
          },
          "context": {
            "default": "",
            "description": "Assembled context string from matching chunks",
            "title": "Context",
            "type": "string"
          },
          "domains_searched": {
            "description": "Domains that were actually searched",
            "items": {
              "type": "string"
            },
            "title": "Domains Searched",
            "type": "array"
          },
          "graph_results": {
            "default": 0,
            "description": "Results contributed by graph expansion",
            "minimum": 0.0,
            "title": "Graph Results",
            "type": "integer"
          },
          "results": {
            "description": "All results with full metadata",
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Results",
            "type": "array"
          },
          "sources": {
            "description": "Result chunks with relevance scores and metadata",
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Sources",
            "type": "array"
          },
          "token_budget_used": {
            "default": 0,
            "description": "Character count of assembled context",
            "minimum": 0.0,
            "title": "Token Budget Used",
            "type": "integer"
          },
          "total_results": {
            "default": 0,
            "description": "Total results after dedup and filtering",
            "minimum": 0.0,
            "title": "Total Results",
            "type": "integer"
          }
        },
        "title": "SDKQueryResponse",
        "type": "object"
      }
    }
  },
  "info": {
    "contact": {
      "name": "Cerid AI",
      "url": "https://github.com/Cerid-AI/cerid-ai"
