    "description": "Stable versioned API for Cerid AI consumers.  Send X-Client-ID for per-client rate limiting and domain scoping.",
    "license": {
      "name": "Apache-2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    },
    "title": "Cerid AI SDK",
    "version": "1.1.0"
  },
