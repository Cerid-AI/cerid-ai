# Cerid AI — Caddy Reverse Proxy
# Provides automatic HTTPS on the local network via self-signed certs.
# Start with: CERID_GATEWAY=true ./scripts/start-cerid.sh

{
	# Use self-signed certs for local HTTPS (no external CA needed)
	local_certs
}

:443 {
	tls internal

	# React GUI (primary interface)
	handle / {
		reverse_proxy cerid-web:80
	}
	handle /assets/* {
		reverse_proxy cerid-web:80
	}
	handle /env-config.js {
		reverse_proxy cerid-web:80
	}
	handle /cerid-logo.svg {
		reverse_proxy cerid-web:80
	}

	# MCP API
	handle /api/mcp/* {
		uri strip_prefix /api/mcp
		reverse_proxy ai-companion-mcp:8888
	}

	# Bifrost LLM Gateway (SSE streaming)
	handle /api/bifrost/* {
		uri strip_prefix /api/bifrost
		reverse_proxy bifrost:8080 {
			flush_interval -1
		}
	}

	# Default: SPA fallback
	handle {
		reverse_proxy cerid-web:80
	}
}
