# Cerid AI — Environment Variables
# Copy this file to .env and fill in your values.

# Neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Categorization mode: manual | smart | pro
CATEGORIZE_MODE=smart

# Webhook URLs (comma-separated, optional)
# WEBHOOK_URLS=https://your-webhook.example.com/cerid

# Schedule overrides (cron expressions, optional)
# SCHEDULE_RECTIFY=0 3 * * *
# SCHEDULE_HEALTH_CHECK=0 */6 * * *
# SCHEDULE_STALE_DETECTION=0 4 * * 0
# SCHEDULE_STALE_DAYS=90
