#!/usr/bin/env bash
# Pre-commit hook: verify lock files are in sync with their sources.
# Install: git config core.hooksPath scripts/hooks

set -e

staged=$(git diff --cached --name-only)

# Python: if requirements.txt changed, requirements.lock must also be staged
if echo "$staged" | grep -q "src/mcp/requirements.txt"; then
  if ! echo "$staged" | grep -q "src/mcp/requirements.lock"; then
    echo "ERROR: src/mcp/requirements.txt is staged but requirements.lock is not."
    echo "Run: cd src/mcp && pip-compile requirements.txt -o requirements.lock --generate-hashes --no-header --allow-unsafe"
    exit 1
  fi
fi

# Python dev: same check for dev deps
if echo "$staged" | grep -q "src/mcp/requirements-dev.txt"; then
  if ! echo "$staged" | grep -q "src/mcp/requirements-dev.lock"; then
    echo "ERROR: src/mcp/requirements-dev.txt is staged but requirements-dev.lock is not."
    echo "Run: cd src/mcp && pip-compile requirements-dev.txt -o requirements-dev.lock --generate-hashes --no-header --allow-unsafe"
    exit 1
  fi
fi

# NPM: if package.json changed, package-lock.json must also be staged
if echo "$staged" | grep -q "src/web/package.json"; then
  if ! echo "$staged" | grep -q "src/web/package-lock.json"; then
    echo "ERROR: src/web/package.json is staged but package-lock.json is not."
    echo "Run: cd src/web && npm install"
    exit 1
  fi
fi
