{
  "name": "@cerid-ai/widget",
  "version": "0.1.0",
  "description": "Embeddable chat widget for Cerid AI Knowledge Companion",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/cerid-widget.js",
  "module": "./dist/cerid-widget.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/cerid-widget.esm.js",
      "require": "./dist/cerid-widget.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean && vite build",
    "build:widget": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-css-injected-by-js": "^3.5.0"
  },
  "keywords": [
    "cerid",
    "chat-widget",
    "embeddable",
    "knowledge-base",
    "rag"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Cerid-AI/cerid-ai.git",
    "directory": "packages/widget"
  },
  "homepage": "https://cerid.ai"
}
